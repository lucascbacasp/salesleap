# ─── App ───────────────────────────────────────────────────
APP_NAME=SalesLeap
DEBUG=false
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://salesleap:CHANGE_ME@postgres:5432/salesleap
POSTGRES_USER=salesleap
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=salesleap

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Anthropic (Claude API) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Auth ──────────────────────────────────────────────────
MAGIC_LINK_EXPIRE_MINUTES=15
JWT_EXPIRE_HOURS=168

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=["https://salesleap.app"]

# ─── Email (SMTP for magic links) ─────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@salesleap.app
SMTP_PASS=CHANGE_ME
EMAIL_FROM=noreply@salesleap.app

# ─── Storage (S3 for company documents) ───────────────────
S3_BUCKET=salesleap-docs
S3_REGION=us-east-1
AWS_ACCESS_KEY=CHANGE_ME
AWS_SECRET_KEY=CHANGE_ME
